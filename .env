# =============================================
# Pharmacy Smart Shortage Manager
# Environment Configuration
# =============================================

# Database
POSTGRES_DB=pharmacy_shortage
POSTGRES_USER=pharmacy_admin
POSTGRES_PASSWORD=pharmacy_secure_2024
DATABASE_URL=postgresql+asyncpg://pharmacy_admin:pharmacy_secure_2024@localhost:5432/pharmacy_shortage

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000

# Upload Settings
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=./uploads

# OCR Configuration
OCR_ENGINE=tesseract
OCR_LANGUAGE=en,ar
OCR_CONFIDENCE_THRESHOLD=0.6
# TESSERACT_PATH auto-detected on Linux (Render), set manually for Windows only

# Shortage Defaults
DEFAULT_MIN_STOCK=10

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================
# Pharmacy Smart Shortage Manager
# Environment Configuration — Production Ready
# =============================================
#
# DEPLOYMENT TARGETS:
# - Frontend: Vercel
# - Backend: Render
# - Database: Render PostgreSQL
#
# Copy to .env for local development, or set as environment variables
# on your deployment platforms.
#
# NOTE: Never commit actual secrets to version control!
# =============================================

# =============================================
# DATABASE (Render PostgreSQL)
# =============================================
# Provided automatically by Render when you link the database
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# DATABASE_ECHO=false

# =============================================
# SECURITY
# =============================================
# Generate a secure random string: openssl rand -hex 32
SECRET_KEY=your-secure-random-secret-key-here-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440  # 24 hours

# =============================================
# CORS — Comma-separated list of allowed origins
# =============================================
# LOCAL DEVELOPMENT:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PRODUCTION (uncomment and update for production):
# CORS_ORIGINS=https://your-app.vercel.app,https://your-backend.onrender.com

# =============================================
# FILE UPLOADS
# =============================================
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=.png,.jpg,.jpeg,.bmp,.tiff,.xlsx,.xls,.csv,.pdf

# =============================================
# OCR CONFIGURATION
# =============================================
# Engine: tesseract (recommended for Render) | paddleocr
OCR_ENGINE=tesseract
OCR_LANGUAGE=en,ar
OCR_CONFIDENCE_THRESHOLD=0.6

# Tesseract path (auto-detected on Render Linux at /usr/bin/tesseract)
# Leave empty for auto-detection, or set explicit path:
# TESSERACT_PATH=/usr/bin/tesseract

# =============================================
# SHORTAGE DEFAULTS
# =============================================
DEFAULT_MIN_STOCK=10

# =============================================
# APPLICATION
# =============================================
DEBUG=false
APP_NAME=Pharmacy Smart Shortage Manager
APP_VERSION=1.0.0

# =============================================
# FRONTEND (Vercel) — NEXT_PUBLIC_ prefix required
# =============================================
# Set this on Vercel dashboard under Environment Variables
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api/v1